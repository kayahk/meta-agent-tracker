META_AGENT_DATABASE_URL=./data/meta-agent.sqlite
META_AGENT_LOG_LEVEL=info
META_AGENT_API_HOST=127.0.0.1
META_AGENT_API_PORT=4317
META_AGENT_SCAN_INTERVAL_MS=3600000

# Outbound delivery (optional). Leave empty for no-op delivery.
META_AGENT_HERMES_ENDPOINT=
META_AGENT_HERMES_WEBHOOK_SECRET=
META_AGENT_AGENT_EVENT_TOKEN=

# GitHub App / webhook configuration. Keep secrets in your local .env or secret manager.
META_AGENT_GITHUB_APP_ID=
META_AGENT_GITHUB_PRIVATE_KEY_PATH=
META_AGENT_GITHUB_WEBHOOK_SECRET=
META_AGENT_GITHUB_INSTALLATION_ID=
META_AGENT_GITHUB_REPOSITORIES=example-org/example-service,example-org/example-api
META_AGENT_GITHUB_ASSIGNED_TO=alice,bob
META_AGENT_GITHUB_PLAN_REPOSITORIES=example-org/example-service
META_AGENT_GITHUB_PLAN_DOCS_PATH=docs

# Jira Cloud (optional; Basic Auth with email + API token).
META_AGENT_JIRA_URL=https://jira.example.com
META_AGENT_JIRA_EMAIL=user@example.com
META_AGENT_JIRA_PAT=
META_AGENT_JIRA_WEBHOOK_SECRET=

# Confluence (optional; bearer token/PAT).
META_AGENT_CONFLUENCE_URL=https://confluence.example.com
META_AGENT_CONFLUENCE_PAT=
META_AGENT_CONFLUENCE_SPACES=ENG,PROD

# LLM-assisted advisory matching (optional; proposed links are not authoritative).
META_AGENT_LLM_API_URL=
META_AGENT_LLM_API_KEY=
META_AGENT_LLM_MODEL=
